void display_one(market temp) {
    cout << temp.name << '\n';
    cout << "ПВЗ: " << temp.pvz << '\n';
    cout << "Город: " << temp.gorod.name << '\n';
    cout << "Стоимость: $" << temp.stoimost << '\n';
    if (temp.tip == PRODUCT)
    cout << "Тип: продуктовый\n";
    else if (temp.tip == HOME)
        cout << "Тип: товары для дома\n";
    else
        cout << "Тип: все-подряд\n";
    if (temp.biz == MAIN_BUS)
        cout << "Бизнес: основной\n";
    else if (temp.biz == HELP_BUS)
        cout << "Бизнес: вспомогательный\n";
    else
        cout << "Бизнес: франшиза\n";

    cout << '\n';
}

void display_all(market arr[], int kol) {
    int t;
    for (t = 0; t < kol; t++) {
        if (arr[t].name[0] != '\0') {    
            display_one(arr[t]);
        }
    }
}

void filter_home() {
    int i;
    kol_dom = 0;
    for (i = 0; i < SIZE; i++) {
        if (magaz[i].name[0] != '\0' && magaz[i].tip == HOME) {
            domashnie[kol_dom] = magaz[i];   
            kol_dom++;
        }
    }
}

void bubble_sort(market arr[], int kol) {
    int i, j;
    market temp;

    for (i = 0; i < kol - 1; i++) {
        for (j = 0; j < kol - i - 1; j++) {
            if (arr[j].stoimost > arr[j + 1].stoimost) {
                temp = arr[j];           
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

void filter_moscow() {
    int i;
    kol_mos = 0;
    for (i = 0; i < SIZE; i++) {
        if (magaz[i].name[0] != '\0') {
            if (strcmp(magaz[i].gorod.name, "Moscow") == 0) {  
                moskva[kol_mos] = magaz[i];
                kol_mos++;
            }
        }
    }
}

void update() {
    int i;
    char name[80];

    cout << "\nВведите название маркетплейса: ";
    cin >> name;

    for (i = 0; i < SIZE; i++) {
        if (strcmp(name, magaz[i].name) == 0)  
            break;
    }

    if (i == SIZE) {
        cout << "Товар не найден.\n";
        return;
    }

    cout << "Введите новую информацию.\n";
    cout << "Название: ";
    cin >> magaz[i].name;
    cout << "ПВЗ: ";
    cin >> magaz[i].pvz;
    cout << "Город: ";
    cin >> magaz[i].gorod.name;
    cout << "Стоимость: ";
    cin >> magaz[i].stoimost;

    int tip_choice;
    cout << "Тип (0-продуктовый, 1-товары для дома, 2-все-подряд): ";
    cin >> tip_choice;
    magaz[i].tip = (market_type)tip_choice;

    int biz_choice;
    cout << "Бизнес (0-основной, 1-вспомогательный, 2-франшиза): ";
    cin >> biz_choice;
    magaz[i].biz = (business_type)biz_choice;

    cout << "Данные обновлены!\n";
}

void two_from_city() {
    int i, j, k;
    char cities[SIZE][40];
    int kol_cities = 0;
      for (i = 0; i < SIZE; i++) {
        if (magaz[i].name[0] != '\0') {
            if (strcmp(magaz[i].gorod.name, "Moscow") != 0) {
                int found = 0;
                for (j = 0; j < kol_cities; j++) {
                    if (strcmp(cities[j], magaz[i].gorod.name) == 0) {
                        found = 1;
                        break;
                    }
                }
                if (!found) {
                    strcpy(cities[kol_cities], magaz[i].gorod.name);
                    kol_cities++;
                }
            }
        }
    }
    for (i = 0; i < kol_cities; i++) {
        market city_arr[SIZE];
        int kol_city = 0;
        for (j = 0; j < SIZE; j++) {
            if (magaz[j].name[0] != '\0') {
                if (strcmp(magaz[j].gorod.name, cities[i]) == 0) {
                    city_arr[kol_city] = magaz[j];
                    kol_city++;
                }
            }
        }

        bubble_sort(city_arr, kol_city);
        if (kol_city >= 2) {
            cout << "\nГород: " << cities[i] << "\n";
            cout << "1. " << city_arr[kol_city - 1].name
                << " - $" << city_arr[kol_city - 1].stoimost << "\n";
            cout << "2. " << city_arr[kol_city - 2].name
                << " - $" << city_arr[kol_city - 2].stoimost << "\n";
        }
    }
}

void show_filtered() {
    filter_home();
    bubble_sort(domashnie, kol_dom);
    cout << "\nТовары для дома отсортированные \n";
    display_all(domashnie, kol_dom);
    filter_moscow();
    cout << "\nМаркетплейсы Москвы\n";
    display_all(moskva, kol_mos);
    two_from_city();
}

