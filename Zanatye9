    char choice;
    for (;;) {
        choice = menu();
        switch (choice) {
        case '1':
            filter_home();
            bubble_sort(domashnie, kol_dom);
            cout << "\nМаркетплейсы с товарами для дома\n";
            display_all(domashnie, kol_dom);
            break;
        case '2':
            cout << "\nВсе маркетплейсы\n";
            display_all(magaz, SIZE);
            break;
        case '3':
            update();          
            break;
        case '4':
            show_filtered();
            break;
        case '0':
            return 0;          
        }
    }
}
